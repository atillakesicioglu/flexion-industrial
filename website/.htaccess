Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Gerçek dosya veya dizin ise dokunma
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. .php uzantısız talep → karşılık gelen .php dosyası varsa yönlendir
    #    Örnek: /sectors → sectors.php, /category?id=1 → category.php?id=1
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L,QSA]

    # 3. Kurumsal sayfa slug'ları (admin / includes / assets hariç)
    RewriteCond %{REQUEST_URI} !^/admin/
    RewriteCond %{REQUEST_URI} !^/includes/
    RewriteCond %{REQUEST_URI} !^/assets/
    RewriteRule ^([a-z0-9][a-z0-9\-]*)/?$ page.php?slug=$1 [L,QSA]
</IfModule>

# ---- Güvenlik başlıkları ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- PHP dosyalarında hata gösterme (production) ----
php_flag display_errors Off
